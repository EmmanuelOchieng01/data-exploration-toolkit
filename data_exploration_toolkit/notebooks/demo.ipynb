import pandas as pd
from src.data_cleaning import load_data, clean_missing, drop_duplicates
from src.eda import summary, plot_distribution, correlation_matrix
from src.utils import save_clean

# Load sample dataset
df = pd.read_csv('https://raw.githubusercontent.com/mwaskom/seaborn-data/master/titanic.csv')

# Clean data
df = clean_missing(df)
df = drop_duplicates(df)

# EDA
summary(df)
plot_distribution(df, 'age')
correlation_matrix(df)

# Save cleaned data
save_clean(df, 'data/cleaned_titanic.csv')
